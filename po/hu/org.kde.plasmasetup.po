#: modules/account/contents/ui/main.qml:79
#, kde-format
msgid "We need a few details to complete the setup."
msgstr "A beállítás befejezéséhez néhány részletre van szükségünk."

#: modules/account/contents/ui/main.qml:90
#, kde-format
msgctxt "@info"
msgid "This user will be an administrator."
msgstr "Ez a felhasználó rendszergazda lesz."

#: modules/account/contents/ui/main.qml:94
#, kde-kuit-format
msgctxt "@info"
msgid ""
"This user will have administrative privileges on the system.<nl/><nl/>This "
"means that they can change system settings, install software, and access all "
"files on the system.<nl/><nl/>Choose a strong password for this user."
msgstr ""
"Ennek a felhasználónak rendszergazdai jogai lesznek a rendszeren.<nl/><nl/"
">Ez azt jelenti, hogy módosíthatja a rendszer beállításait, szoftvereket "
"telepíthet, és mindenhez hozzáfér a fájlrendszeren.<nl/><nl/>Erős jelszót "
"adjon ennek a felhasználónak."

